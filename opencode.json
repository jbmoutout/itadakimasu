{
  "$schema": "https://opencode.ai/config.json",
  "model": "lmstudio/qwen3.5-9b-unsloth-mlx",
  "provider": {
    "openrouter": {
      "models": {
        "qwen/qwen3.5-9b": {}
      },
      "options": {
        "apiKey": "{env:OPENROUTER_API_KEY}"
      }
    },
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio",
      "options": {
        "baseURL": "http://host.docker.internal:1234/v1"
      },
      "models": {
        "qwen3.5-9b-unsloth-mlx": {
          "name": "Qwen3.5-9B (LM Studio local)",
          "limit": {
            "context": 49152,
            "output": 8192
          }
        }
      }
    }
  }
}
